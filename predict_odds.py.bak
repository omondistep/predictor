#!/usr/bin/env python3
"""
Football Match Predictor — rule-based terminal app.

Analyzes match data (teams + odds) using the same strategy as the manual
analysis workflow: league trends, odds structure, home/away splits, and
market value. Optionally scrapes live form data for refinement.

Usage:
    python predict.py <file>          # Predict from a file of matches
    python predict.py --paste         # Paste matches interactively
    python predict.py --scrape        # Try scraping form data (slower)
"""

import argparse
import csv
import io
import re
import sys
import json
import os
from dataclasses import dataclass, field
from typing import Optional
from datetime import datetime

# ─────────────────────────────────────────────
# Data Models
# ─────────────────────────────────────────────

@dataclass
class MatchOdds:
    """Parsed odds for a single match."""
    home_win: float
    draw: float
    away_win: float
    dc_home_or_draw: float
    dc_home_or_away: float
    dc_draw_or_away: float
    over_25: float
    under_25: float
    btts_yes: float
    btts_no: float

    @classmethod
    def from_list(cls, vals: list[float]) -> "MatchOdds":
        if len(vals) < 10:
            vals += [0.0] * (10 - len(vals))
        return cls(*vals[:10])


@dataclass
class Match:
    """A single match with metadata and odds."""
    home_team: str
    away_team: str
    league: str = ""
    competition: str = ""
    kickoff: str = ""
    match_id: str = ""
    odds: Optional[MatchOdds] = None
    raw_lines: list[str] = field(default_factory=list)


@dataclass
class Prediction:
    """A single prediction output."""
    match: Match
    primary_pick: str          # e.g. "Home win", "Under 2.5", "BTTS Yes"
    correct_score: str = ""    # e.g. "2-1"
    confidence: str = "Medium" # Low / Medium / High / Near Certain
    reasoning: list[str] = field(default_factory=list)
    supporting_markets: list[str] = field(default_factory=list)


# ─────────────────────────────────────────────
# League Profiles
# ─────────────────────────────────────────────

@dataclass
class LeagueProfile:
    """Known statistical profile for a league."""
    name: str
    avg_goals: float = 2.5
    under_25_rate: float = 0.50   # 0-1
    btts_no_rate: float = 0.50
    draw_rate: float = 0.25
    home_win_rate: float = 0.45
    goals_home_avg: float = 1.4
    goals_away_avg: float = 1.1

